            </li>
            <!-- 出售：工具 -->
            <li Class="StockGenerator_SingleDef">
                <thingDef>USAC_DisposableRepairTool</thingDef>
                <countRange>5~20</countRange>
            </li>
            <!-- 出售：電池 -->
            <li Class="StockGenerator_SingleDef">
                <thingDef>USAC_DisposableBattery</thingDef>
