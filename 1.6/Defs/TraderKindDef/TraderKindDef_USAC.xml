            </li>

            <!-- 收购：零件 -->
            <li Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentIndustrial</thingDef>
            </li>
            <li Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentSpacer</thingDef>
            </li>
            <!-- 收购：未受精卵 -->
            <li MayRequire="ludeon.rimworld.biotech" Class="StockGenerator_BuySingleDef">
                <thingDef>HumanOvum</thingDef>
            </li>
            <!-- 收购：受精卵 -->
            <li MayRequire="ludeon.rimworld.biotech" Class="StockGenerator_BuySingleDef">
                <thingDef>HumanEmbryo</thingDef>
            </li>
            <!-- 收购：血包 -->
            <li MayRequire="ludeon.rimworld.biotech" Class="StockGenerator_BuySingleDef">
                <thingDef>HemogenPack</thingDef>
            </li>

            <!-- 收购：中性胺 -->
            <li Class="StockGenerator_BuySingleDef">
                <thingDef>Neutroamine</thingDef>
            </li>

            <li Class="StockGenerator_MarketValue">
                <tradeTag>USAC_Consumable</tradeTag>
                <countRange>7~12</countRange>
            </li>
            <li Class="StockGenerator_MarketValue">
                <tradeTag>USAC_Armor</tradeTag>
                <countRange>7~12</countRange>
            </li>
            <li Class="StockGenerator_MarketValue">
                <tradeTag>USAC_WeaponRanged</tradeTag>
                <countRange>5~10</countRange>
            </li>
            <li Class="StockGenerator_MarketValue">
                <tradeTag>USAC_Ammunition</tradeTag>
                <countRange>1000~3000</countRange>
            </li>

            <!-- 出售：信用债券 -->
            <li Class="USAC.StockGenerator_USACBond">
                <countRange>10~50</countRange>
            </li>

            <!-- DMS聯動 -->

            <!-- 收购：沖壓零件 -->
            <li MayRequire="aoba.deadmanswitch.core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentStamped</thingDef>
            </li>
            <!-- 收购：機兵武器 -->
            <li MayRequire="Aoba.DeadManSwitch.Core" Class="StockGenerator_Category">
                <categoryDef>AutomatroidWeapon</categoryDef>
                <countRange>0~0</countRange>
            </li>
            <!-- 收购：火控系統 -->
            <li MayRequire="Aoba.DeadManSwitch.Core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentFireControl</thingDef>
            </li>
            <!-- 收购：CCC -->
            <li MayRequire="Aoba.DeadManSwitch.Core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentControlChip</thingDef>
            </li>
            <!-- 收购：T/R組件 -->
            <li MayRequire="Aoba.DeadManSwitch.Core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentTransmitter</thingDef>
            </li>

        </stockGenerators>
    </TraderKindDef>
</Defs>