            <!-- 出售：临时机控中枢 -->
            <li Class="StockGenerator_SingleDef" MayRequire="Ludeon.Rimworld.Biotech">
                <thingDef>USAC_TempMechlink</thingDef>
                <countRange>1~3</countRange>
            </li>
            <!-- 出售：神经强化剂 -->
            <li Class="StockGenerator_SingleDef">
                <thingDef>USAC_NeuroBooster</thingDef>
                <countRange>3~10</countRange>
            </li>
            <!-- 出售：活力水 -->
            <li Class="StockGenerator_SingleDef">
                <thingDef>GoJuice</thingDef>
