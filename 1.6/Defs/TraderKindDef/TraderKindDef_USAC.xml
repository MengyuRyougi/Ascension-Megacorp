            </li>
        </modExtensions>
        <stockGenerators>
            <!-- 出售：机兵订单 -->
            <li Class="USAC.StockGenerator_USAC_Mechs">
                <kindCountRange>2~6</kindCountRange>
                <countPerKindRange>1~4</countPerKindRange>
            </li>

            <li Class="StockGenerator_SingleDef">
