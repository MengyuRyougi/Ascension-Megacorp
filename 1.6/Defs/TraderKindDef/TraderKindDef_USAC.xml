<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- USAC 轨道商船 -->
    <TraderKindDef>
        <defName>USAC_Trader_Orbital</defName>
        <label>USAC orbital trader</label>
        <commonality>1</commonality>
        <orbital>true</orbital>
        <faction>USAC_Faction</faction>
        <requestable>false</requestable>
        <hideThingsNotWillingToTrade>true</hideThingsNotWillingToTrade>
        <modExtensions>
            <li Class="USAC.ModExtension_CorpseBagTrader">
                <useCorpseBagCurrency>true</useCorpseBagCurrency>
                <corpseBagDefName>USAC_CorpseBag</corpseBagDefName>
            </li>
        </modExtensions>
        <stockGenerators>
            <!-- 出售：机兵订单 -->
            <li Class="USAC.StockGenerator_USAC_Mechs">
                <kindCountRange>0~2</kindCountRange>
                <countPerKindRange>1~2</countPerKindRange>
                <price>Expensive</price>
            </li>

            <li Class="StockGenerator_SingleDef">
                <thingDef>USAC_MealSurvivalPack</thingDef>
                <countRange>200~500</countRange>
                <price>Cheap</price>
            </li>
            <li Class="StockGenerator_SingleDef">
                <thingDef>MedicineUltratech</thingDef>
                <countRange>10~50</countRange>
                <price>Expensive</price>
            </li>

            <!-- 出售：临时机控中枢 -->
            <li Class="StockGenerator_SingleDef" MayRequire="Ludeon.Rimworld.Biotech">
                <thingDef>USAC_TempMechlink</thingDef>
                <countRange>1~3</countRange>
            </li>
            <!-- 出售：神经强化剂 -->
            <li Class="StockGenerator_SingleDef">
                <thingDef>USAC_NeuroBooster</thingDef>
                <countRange>3~100</countRange>
            </li>
            <!-- 出售：活力水 -->
            <li Class="StockGenerator_SingleDef">
                <thingDef>GoJuice</thingDef>
                <countRange>5~165</countRange>
            </li>
            <!-- 出售：工具 -->
            <li Class="StockGenerator_SingleDef">
                <thingDef>USAC_DisposableRepairTool</thingDef>
                <countRange>5~50</countRange>
            </li>
            <!-- 出售：電池 -->
            <li Class="StockGenerator_SingleDef">
                <thingDef>USAC_DisposableBattery</thingDef>
                <countRange>5~50</countRange>
            </li>

            <!-- 收购：零件 -->
            <li Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentIndustrial</thingDef>
            </li>
            <li Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentSpacer</thingDef>
            </li>
            <!-- 收购：沖壓零件 -->
            <li MayRequire="aoba.deadmanswitch.core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentStamped</thingDef>
            </li>

            <!-- 收购：未受精卵 -->
            <li MayRequire="ludeon.rimworld.biotech" Class="StockGenerator_BuySingleDef">
                <thingDef>HumanOvum</thingDef>
            </li>
            <!-- 收购：受精卵 -->
            <li MayRequire="ludeon.rimworld.biotech" Class="StockGenerator_BuySingleDef">
                <thingDef>HumanEmbryo</thingDef>
            </li>
            <!-- 收购：血包 -->
            <li MayRequire="ludeon.rimworld.biotech" Class="StockGenerator_BuySingleDef">
                <thingDef>HemogenPack</thingDef>
            </li>

            <!-- 收购：中性胺 -->
            <li Class="StockGenerator_BuySingleDef">
                <thingDef>Neutroamine</thingDef>
            </li>

            <li Class="StockGenerator_MarketValue">
                <tradeTag>USAC_Armor</tradeTag>
                <countRange>7~12</countRange>
            </li>

            <li Class="StockGenerator_MarketValue">
                <tradeTag>USAC_Ammunition</tradeTag>
                <countRange>1000~3000</countRange>
            </li>

            <li Class="StockGenerator_MarketValue">
                <tradeTag>USAC_WeaponRanged</tradeTag>
                <countRange>5~10</countRange>
            </li>

            <!-- 出售：信用债券 -->
            <li Class="USAC.StockGenerator_USACBond">
                <countRange>10~150</countRange>
            </li>

            <!-- 收购：化合燃料 -->
            <li Class="StockGenerator_BuySingleDef">
                <thingDef>Chemfuel</thingDef>
                <price>Cheap</price>
            </li>

            <!-- AUR聯動 -->
            <li MayRequire="xmb.ancienturbanruins.mo" Class="StockGenerator_MarketValue">
                <tradeTag>AM_Med</tradeTag>
                <countRange>0~0</countRange>
            </li>
            <li MayRequire="xmb.ancienturbanruins.mo" Class="StockGenerator_MarketValue">
                <tradeTag>AM_Electronics</tradeTag>
                <countRange>0~0</countRange>
                <price>Cheap</price>
            </li>
            <li MayRequire="xmb.ancienturbanruins.mo" Class="StockGenerator_MarketValue">
                <tradeTag>AMGuns</tradeTag>
                <countRange>0~0</countRange>
            </li>
            
  
            <!-- DMS聯動 -->

            <!-- 收购：沖壓零件 -->
            <li MayRequire="aoba.deadmanswitch.core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentStamped</thingDef>
            </li>
            <!-- 收购：機兵武器 -->
            <li MayRequire="Aoba.DeadManSwitch.Core" Class="StockGenerator_Category">
                <categoryDef>AutomatroidWeapon</categoryDef>
                <countRange>0~0</countRange>
            </li>
            <!-- 收购：火控系統 -->
            <li MayRequire="Aoba.DeadManSwitch.Core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentFireControl</thingDef>
            </li>
            <!-- 收购：CCC -->
            <li MayRequire="Aoba.DeadManSwitch.Core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentControlChip</thingDef>
            </li>
            <!-- 收购：T/R組件 -->
            <li MayRequire="Aoba.DeadManSwitch.Core" Class="StockGenerator_BuySingleDef">
                <thingDef>ComponentTransmitter</thingDef>
            </li>
        </stockGenerators>
    </TraderKindDef>

    <TraderKindDef>
        <defName>USAC_Trader_MechSupplier</defName>
