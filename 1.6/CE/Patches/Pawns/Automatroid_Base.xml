<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="USAC_Mech_Rocky"]/inspectorTabs/li[.="ITab_Pawn_Gear"]</xpath>
		<value>
			<li>CombatExtended.ITab_Inventory</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationAdd">
				<xpath>Defs/PawnKindDef[@Name="USAC_Base"]</xpath>
				<value>
					<aiAvoidCover>false</aiAvoidCover>
				</value>
			</li>

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[@Name="USAC_BaseMechRace"]/statBases</xpath>
				<value>
					<SmokeSensitivity>0</SmokeSensitivity>
					<NightVisionEfficiency>0.25</NightVisionEfficiency>
				</value>
			</li>

			<li Class="PatchOperationConditional">
				<xpath>Defs/ThingDef[@Name="USAC_BaseMechRace"]/comps</xpath>
				<nomatch Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[@Name="USAC_BaseMechRace"]</xpath>
					<value>
						<comps />
					</value>
				</nomatch>
			</li>

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[@Name="USAC_BaseMechRace"]/comps</xpath>
				<value>
					<li>
						<compClass>CombatExtended.CompAmmoGiver</compClass>
					</li>
					<li Class="CombatExtended.CompProperties_MechAmmo">
						<gizmoIconSetMagCount>UI/Buttons/SetMagCount</gizmoIconSetMagCount>
						<gizmoIconTakeAmmoNow>UI/Buttons/TakeAmmoNow</gizmoIconTakeAmmoNow>
					</li>
				</value>
			</li>

			<li Class="PatchOperationAddModExtension">
				<xpath>Defs/ThingDef[@Name="USAC_BaseMechRace"]</xpath>
				<value>
					<li Class="CombatExtended.PartialArmorExt">
						<stats>
							<li>
								<ArmorRating_Sharp>0.25</ArmorRating_Sharp>
								<parts>
									<li>SightSensor</li>
									<li>HearingSensor</li>
									<li>SmellSensor</li>
								</parts>
							</li>
							<li>
								<ArmorRating_Blunt>0.25</ArmorRating_Blunt>
								<parts>
									<li>SightSensor</li>
									<li>HearingSensor</li>
									<li>SmellSensor</li>
								</parts>
							</li>
						</stats>
					</li>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[@Name="USAC_BaseMechRace"]/tools</xpath>
				<value>
					<tools>
						<li Class="CombatExtended.ToolCE">
							<label>head</label>
							<capacities>
								<li>Blunt</li>
							</capacities>
							<power>6</power>
							<cooldownTime>1.85</cooldownTime>
							<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
							<chanceFactor>0.2</chanceFactor>
							<armorPenetrationBlunt>0.625</armorPenetrationBlunt>
						</li>
					</tools>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[@Name="USAC_BaseHeavyBipedMech" or @Name="USAC_BaseQuadMech" or @Name="USAC_BaseHumanoidMech"]/tools</xpath>
				<value>
					<tools>
						<li Class="CombatExtended.ToolCE">
							<label>left fist</label>
							<capacities>
								<li>Blunt</li>
							</capacities>
							<power>10</power>
							<cooldownTime>1.11</cooldownTime>
							<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
							<armorPenetrationBlunt>4.788</armorPenetrationBlunt>
							<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
						</li>
						<li Class="CombatExtended.ToolCE">
							<label>right fist</label>
							<capacities>
								<li>Blunt</li>
							</capacities>
							<power>10</power>
							<cooldownTime>1.11</cooldownTime>
							<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
							<armorPenetrationBlunt>4.788</armorPenetrationBlunt>
							<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
						</li>
					</tools>
				</value>
			</li>

		</operations>
	</Operation>
</Patch>